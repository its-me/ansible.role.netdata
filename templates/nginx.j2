{% for host in groups['all'] %}
upstream netdata-{{ hostvars[host]['inventory_hostname_short'] }} {
    server {{ hostvars[host]['inventory_hostname'] }}:19999;
    keepalive 64;
}
{% endfor %}


server {
    listen 443 ssl;
    server_name {{ netdata_nginx_server_name }};

    ssl on;
    ssl_certificate     /etc/ssl/certs/ssl-cert-snakeoil.pem;
    ssl_certificate_key /etc/ssl/private/ssl-cert-snakeoil.key;
    ssl_protocols       TLSv1 TLSv1.1 TLSv1.2;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    location ~ /(?<behost>.*)/(?<ndpath>.*) {
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Server $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass http://netdata-$behost/$ndpath$is_args$args;
        proxy_http_version 1.1;
        proxy_pass_request_headers on;
        proxy_set_header Connection "keep-alive";
        proxy_store off;
    }

    # make sure there is a trailing slash at the browser
    # or the URLs will be wrong
    location ~ /(?<behost>.*) {
        return 301 /$behost/;
    }
}